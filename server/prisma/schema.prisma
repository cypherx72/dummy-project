enum MediaType {
  image 
  video
  pdf
  text
}

model Message {
  id           String     @id @default(cuid())
  senderId     String     @map("sender_id")
  content      String?
  createdAt    DateTime   @default(now()) @map("created_at")
  replyToId    String?

  deliveredAt  DateTime?  @map("delivered_at")
  readAt       DateTime?  @map("read_at")

  chatId String @map("chat_id")
  chat Chat @relation(fields: [chatId], references: [id])
  mediaId      String?    @unique @map("media_id")
  media        Media?     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  replyTo      Message?   @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: Cascade) 
  replies      Message[]  @relation("MessageReplies") 

  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  // add a edited msg field of type boolean 
  // add a star field also... 
  // learn cascading... 
  
  reactions    Reaction[]
  @@map("messages")
}



model ChatMember { 
  id String @id @default(cuid())
  chatId String @map("chat_id") 
  userId String @map("user_id") 
  role userRole 
  isMuted Boolean @default(false) @map("is_muted")

  joinedAt DateTime @default(now()) @map("joined_at")
  unreadMessageCount Int @default(0) @map("unread_message_count")
    chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 reactions    Reaction[]

 @@unique([chatId, userId])
  @@map("chatMembers")
}

model Link { 
  id String @id @default(cuid())
courseId String @map("course_id")
chatId String @map("chat_id") @unique
associate linkAssociate 
createdBy String @map("created_by") // relate to teacher who created it
startsAt DateTime? @map("starts_at")
endsAt DateTime? @map("ends_at")
createdAt DateTime @default(now()) @map("created_at")
chat Chat @relation(fields: [chatId], references: [id])

  @@map("links")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id") 
  chatMemberId    String   @map("chat_member_id") 
  emoji     String   

  createdAt DateTime @default(now()) @map("created_at")

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chatMember      ChatMember     @relation(fields: [chatMemberId], references: [id], onDelete: Cascade)

  @@map("reactions")
}

model Media {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now()) @map("created_at")

  cloudinary_url  String
  size            String
  name            String
  file_extension  String
  resource_type   String
  public_id       String
  status          fileStatus  @default(pending)
  associate       fileAssociate
  message Message?

  @@map("files")
}



// Table Enums //

enum userRole { 
  student
  staffMember
}

 enum fileStatus {
  pending
  completed
  cancelled
}

enum fileAssociate { 
  task
  chat 
  threaded
}

enum linkAssociate { 
  zoomLink 
  other
}

enum threadStatus { 
  pending 
  rejected
  approved
}

enum chatType { 
  course 
  thread 
  dm
}


