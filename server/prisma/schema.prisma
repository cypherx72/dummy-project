// Authentication Models

model Account {
id String @id @default(cuid())
userId String @map("user_id")
type String
provider String
providerAccountId String @map("provider_account_id")
password String?
refresh_token String? @db.Text
access_token String? @db.Text
expires_at DateTime?
token_type String?
scope String?
id_token String? @db.Text
session_state String?

user User @relation(fields: [userId], references: [id], onDelete: Cascade)

@@unique([provider, providerAccountId])
@@map("accounts")
}

model Session {
id String @id @default(cuid())
sessionToken String @unique @map("session_token")
userId String @map("user_id")
expiresAt DateTime
user User @relation(fields: [userId], references: [id], onDelete: Cascade)

@@map("sessions")
}

model User {
id String @id @default(cuid())
name String?
email String? @unique
emailVerified DateTime? @map("email_verified")
createdAt DateTime @default(now()) @map("created_at")
image String?

isActive Boolean @default(false)

role userRole @default(student)

accounts Account[]
sessions Session[]
tokens Token[]
sender Sender?

// relations
coursesTeaching Course[] @relation("TeacherCourses")
enrollments Enrollment[]
notifications Notification[]
activities Activity[]
tasks Task[]
submission Submission[]
events Event[]
assignments Assignment[]

@@map("users")
}

enum userRole {
student
teacher
admin
}

model Token {
id String @id @default(cuid())
token String? @unique
type TokenType
expiresAt DateTime @map("expires_at")

userId String @map("user_id")
user User @relation(fields: [userId], references: [id], onDelete: Cascade)

createdAt DateTime @default(now()) @map("created_at")

@@map("tokens")
}

enum TokenType {
activation_token
reset_token
}

// Chat Models

model Sender {
id String @id @default(cuid())
userId String @unique

user User @relation(fields: [userId], references: [id], onDelete: Cascade)

messages Message[]
chatMembers ChatMember[]
pinnedBy PinnedMessage[]
pollVotes PollVote[]
starredMessages StarredMessage[]
@@index([userId])
}

enum chatType {
course
thread
announcement  
}

model Chat {
id String @id @default(cuid())
type chatType
courseId String? @unique @map("course_id")
imageUrl String? @map("image_url")

lastMessageId String?
lastMessage Message? @relation("LastMessage", fields: [lastMessageId], references: [id])

createdAt DateTime @default(now()) @map("created_at")
updatedAt DateTime @updatedAt @map("updated_at")

course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

messages Message[]
chatMembers ChatMember[]
pinnedMessages PinnedMessage[]
links Link[]
polls Poll[]

@@map("chats")
}

model MessageReceipt {
id String @id @default(cuid())

messageId String
chatMemberId String

deliveredAt DateTime?
readAt DateTime?

message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
chatMember ChatMember @relation(fields: [chatMemberId], references: [id], onDelete: Cascade)

@@unique([messageId, chatMemberId])
@@index([messageId])
}

enum MediaType {
image
video
pdf
text
}

model Message {
id String @id @default(cuid())
senderId String @map("sender_id")
content String?
createdAt DateTime @default(now()) @map("created_at")
edited Boolean @default(false)

replyToId String?

chatId String @map("chat_id")
chat Chat @relation(fields: [chatId], references: [id])
mediaId String? @unique @map("media_id")
deleted Boolean @default(false)

media Media? @relation(fields: [mediaId], references: [id], onDelete: Cascade)

replyTo Message? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: Cascade)
replies Message[] @relation("MessageReplies")
lastMessageForChats Chat[] @relation("LastMessage")

sender Sender @relation(fields: [senderId], references: [id], onDelete: Cascade)

pinnedMessages PinnedMessage[]

starredMessages StarredMessage[]
messageReceipts MessageReceipt[]

reactions Reaction[]
@@map("messages")
@@index([chatId, createdAt])
}

model PinnedMessage {
id String @id @default(cuid())

chatId String
messageId String
pinnedById String

pinnedAt DateTime @default(now())

chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
pinnedBy Sender @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

@@unique([chatId, messageId])
@@index([messageId])
}

model StarredMessage {
id String @id @default(cuid())
senderId String
messageId String
createdAt DateTime @default(now())

sender Sender @relation(fields: [senderId], references: [id], onDelete: Cascade)
message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

@@unique([senderId, messageId])
@@index([messageId])
}

model ChatMember {
id String @id @default(cuid())
chatId String
senderId String

isMuted Boolean @default(false)
canSendMessages Boolean @default(true)

joinedAt DateTime @default(now())
unreadMessageCount Int @default(0)

chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
sender Sender @relation(fields: [senderId], references: [id], onDelete: Cascade)

reactions Reaction[]
messageReceipts MessageReceipt[]

@@unique([chatId, senderId])
}

model Poll {
id String @id @default(cuid())
chatId String
question String
createdBy String
createdAt DateTime @default(now())
endsAt DateTime?

chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
options PollOption[]
}

model PollOption {
id String @id @default(cuid())
pollId String
text String

poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
votes PollVote[]
}

model PollVote {
id String @id @default(cuid())
optionId String
userId String

option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
user Sender @relation(fields: [userId], references: [id], onDelete: Cascade)

@@unique([optionId, userId])
}

enum linkAssociate {
zoomLink
}

model Link {
id String @id @default(cuid())
courseId String @map("course_id")
chatId String @map("chat_id") @unique
associate linkAssociate
createdBy String @map("created_by") // relate to teacher who created it
startsAt DateTime? @map("starts_at")
endsAt DateTime? @map("ends_at")
createdAt DateTime @default(now()) @map("created_at")
chat Chat @relation(fields: [chatId], references: [id])

@@map("links")
}

model Reaction {
id String @id @default(cuid())
messageId String @map("message_id")
chatMemberId String @map("chat_member_id")
emoji String

createdAt DateTime @default(now()) @map("created_at")

message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
chatMember ChatMember @relation(fields: [chatMemberId], references: [id], onDelete: Cascade)

@@map("reactions")
@@index([messageId])
}

enum mediaAssociate {
task
chat
threaded
}

enum mediaStatus {
pending
completed
cancelled
}

model Media {
id String @id @default(cuid())
createdAt DateTime @default(now()) @map("created_at")

cloudinary_url String
bytes Int
name String
file_extension String
resource_type String
public_id String
status mediaStatus @default(pending)
associate mediaAssociate
message Message?


 /*
  this has to be changed to something like file_associate_id, since the files are stored for different table
 */
assignmentId String? 
submissionId String?
submission Submission? @relation(fields: [submissionId], references: [id])
assignment Assignment? @relation(fields: [assignmentId], references: [id])
@@map("media")
}

// Assignemnts schema

model Department {
id String @id @default(cuid())
name String
code String
createdAt DateTime @default(now())

courses Course[]

@@map("departments")
}

model Course {
id String @id @default(cuid())
name String
code String
description String?

departmentId String
teacherId String

createdAt DateTime @default(now())

department Department @relation(fields: [departmentId], references: [id])
teacher User @relation("TeacherCourses", fields: [teacherId], references: [id])

assignments Assignment[]
enrollments Enrollment[]
events Event[]
activities Activity[]
chat Chat?

@@map("courses")
}
model Event {
id String @id @default(cuid())
title String
description String?

startTime DateTime
endTime DateTime?

location String?

courseId String?

createdBy String
createdAt DateTime @default(now())

course Course? @relation(fields: [courseId], references: [id])
creator User @relation(fields: [createdBy], references: [id])

@@map("events")
}

model Notification {
id String @id @default(cuid())

userId String

title String
message String

type NotificationType @default(system)

isRead Boolean @default(false)

createdAt DateTime @default(now())

user User @relation(fields: [userId], references: [id])

@@map("notifications")
}

enum NotificationType {
assignment
course
system
}

model Enrollment {
id String @id @default(cuid())

userId String
courseId String

enrolledAt DateTime @default(now())

user User @relation(fields: [userId], references: [id])
course Course @relation(fields: [courseId], references: [id])

@@unique([userId, courseId])
@@map("enrollments")
}


enum SubmissionStatus {
  graded 
  submitted
  pending
  missed
  late
}
model Submission {
  id           String           @id @default(cuid())
  submittedText String?
  marksObtained Int?
  feedback String?
  submittedAt  DateTime         @default(now())
  status       SubmissionStatus @default(pending)

  assignmentId String
  submittedById String

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    User       @relation(fields: [submittedById], references: [id])
  attachments Media[]

  @@map("submissions")
}

model Assignment {
  id String @id @default(cuid())

  title String
  description String
  instructions String?
  
  dueDate DateTime
  courseId String
  createdById String

  maxMarks Int
  allowLateSubmission Boolean @default(false)

  submissionType SubmissionType 
  priority Priority @default(low)

  postedDate DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Media[]
  submissions Submission[]
  course Course @relation(fields: [courseId], references: [id])
  teacher User @relation(fields: [createdById], references: [id])

  @@map("assignments")
}

enum SubmissionType { 
    fileUpload 
    textEntry
    websiteUrl
}
enum Priority { 
    high 
    medium 
    low
}

model Activity {
id String @id @default(cuid())

userId String
courseId String?

type ActivityType
description String

createdAt DateTime @default(now())

user User @relation(fields: [userId], references: [id])
course Course? @relation(fields: [courseId], references: [id])

@@map("activities")
}

enum ActivityType {
submission
comment
upload
login
}

model Task {
id String @id @default(cuid())

userId String

title String
dueTime DateTime?

completed Boolean @default(false)

createdAt DateTime @default(now())

user User @relation(fields: [userId], references: [id])

@@map("tasks")
}
